<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Игровой форум' %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <a href="/" class="logo">🎮 ИгроФорум</a>
    <nav>
      <% if (currentUser) { %>
        <span class="user-greeting">Привет, <%= currentUser %></span>
        <a href="/threads/new" class="btn-link">+ Новая тема</a>
        <form action="/logout" method="POST" class="inline-form">
          <button type="submit" class="btn-link">Выйти</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn-link">Войти</a>
        <a href="/register" class="btn-link">Регистрация</a>
      <% } %>
    </nav>
  </header>
  <main class="container">
