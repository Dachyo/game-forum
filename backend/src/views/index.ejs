<%- include('_header', { title: 'ИгроФорум — главная' }) %>

<h1>Категории</h1>
<div class="category-grid">
  <% categories.forEach(c => { %>
    <a href="/category/<%= c.slug %>" class="category-card"><%= c.name %></a>
  <% }) %>
</div>

<h2>Последние темы</h2>
<% if (threads.length === 0) { %>
  <p class="empty-state">Пока нет ни одной темы. Будь первым!</p>
<% } %>
<ul class="thread-list">
  <% threads.forEach(t => { %>
    <li class="thread-item">
      <a href="/threads/<%= t.id %>" class="thread-title"><%= t.title %></a>
      <div class="thread-meta">
        <span class="category-tag"><%= t.category_name %></span>
        автор <%= t.username %> · ответов: <%= t.post_count %>
      </div>
    </li>
  <% }) %>
</ul>

<%- include('_footer') %>
