# Скопируйте этот файл в .env и подставьте свои значения.
# .env в git не коммитится (см. .gitignore) — в проде эти же
# переменные задаются через docker-compose.yml на сервере.

PORT=3000

DB_HOST=db
DB_PORT=5432
DB_USER=forum
DB_PASSWORD=change-me
DB_NAME=forum

SESSION_SECRET=replace-with-a-long-random-string
